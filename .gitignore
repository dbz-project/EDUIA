# Modelos — demasiado grandes para Git (1-3 GB cada uno)
runtime/models/*.gguf
runtime/models/*.bin
!runtime/models/.gitkeep

# Binarios compilados de llama.cpp
runtime/llama_cpp_binary/*.exe
runtime/llama_cpp_binary/*.so
runtime/llama_cpp_binary/llama-server*
!runtime/llama_cpp_binary/.gitkeep

# Python
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/
env/
*.egg-info/
dist/
build/

# Base de datos local (datos del usuario, nunca en Git)
*.db
*.sqlite
*.sqlite3

# Variables de entorno
.env
.env.local

# PyInstaller
*.spec
dist/
build/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Archivos temporales
*.tmp
*.temp
