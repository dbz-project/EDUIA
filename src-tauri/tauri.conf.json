{
  "productName": "EduIA",
  "version": "0.1.0",
  "identifier": "es.eduia.student",
  "build": {
    "frontendDist": "../frontend/student"
  },
  "app": {
    "windows": [
      {
        "title": "EduIA — Tu tutor local",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 550,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    }
  }
}
